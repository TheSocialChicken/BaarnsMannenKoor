---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

/*
  VIDEO CAROUSEL — add real YouTube video IDs below.
  Format: { id: "YOUTUBE_VIDEO_ID", title: "Concert titel", year: "2024" }
  Leave the array empty or with placeholders if no videos yet.
*/
const videos = [
  // { id: "dQw4w9WgXcQ", title: "Kerstconcert 2024", year: "2024" },
  // { id: "EXAMPLE_ID2", title: "All You Need is Love", year: "2023" },
];

const galleryPhotos = [
  { src: "8797@2x.jpg", alt: "Baarns MannenKoor concert" },
  { src: "8794@2x.jpg", alt: "Baarns MannenKoor optreden" },
  { src: "8799@2x.jpg", alt: "Baarns MannenKoor concert" },
  { src: "8801@2x.jpg", alt: "Baarns MannenKoor optreden" },
  { src: "8802@2x.jpg", alt: "Baarns MannenKoor concert" },
  { src: "8795@2x.jpg", alt: "Baarns MannenKoor optreden" },
  { src: "6707.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "6708.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "6709.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "6710.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "6711.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "6712.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "6713.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "8547.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "8548.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "8549.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "8550.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "8551.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "8552.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "6721.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "6722.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "6723.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "6724.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "8560.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "8563.jpg",    alt: "Baarns MannenKoor optreden" },
  { src: "8564.jpg",    alt: "Baarns MannenKoor concert"  },
  { src: "8565.jpg",    alt: "Baarns MannenKoor optreden" },
];
---

<Layout
  title="Media"
  description="Video's, foto's, opnames en persberichten van het Baarns MannenKoor."
  activePage="media"
>
  <Hero
    title="Media &amp; Pers"
    subtitle="Video · Foto · Audio · Pers"
    description="Ontdek het Baarns MannenKoor in beeld en geluid."
    backgroundImage={`${base}/images/8782@2x.jpg`}
    compact={true}
  />

  <!-- ═══════════════════════════════════════ VIDEO CAROUSEL -->
  <section class="section" aria-labelledby="video-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="video-heading">Video's</h2>
        <hr class="divider" />
      </div>

      {videos.length > 0 ? (
        <div class="video-carousel" role="region" aria-label="Videogalerij">
          <div class="video-track" id="video-track">
            {videos.map((v, i) => (
              <div class="video-slide" id={`slide-${i}`}>
                <div class="video-embed-wrap">
                  <iframe
                    src={`https://www.youtube-nocookie.com/embed/${v.id}?rel=0`}
                    title={v.title}
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                    loading="lazy"
                  ></iframe>
                </div>
                <p class="video-caption">{v.title} <span class="video-year">({v.year})</span></p>
              </div>
            ))}
          </div>

          {videos.length > 1 && (
            <div class="carousel-controls">
              <button class="carousel-btn" id="prev-btn" aria-label="Vorige video">&#8592;</button>
              <div class="carousel-dots" id="carousel-dots">
                {videos.map((_, i) => (
                  <button class={`dot ${i === 0 ? 'dot--active' : ''}`} data-index={i} aria-label={`Video ${i + 1}`}></button>
                ))}
              </div>
              <button class="carousel-btn" id="next-btn" aria-label="Volgende video">&#8594;</button>
            </div>
          )}
        </div>
      ) : (
        <div class="video-placeholder">
          <span class="video-placeholder-icon" aria-hidden="true">&#9654;</span>
          <h3>Video's binnenkort beschikbaar</h3>
          <p>
            Wij voegen binnenkort opnames van onze concerten toe.
            Volg ons voor updates.
          </p>
          <a href={`${base}/contact`} class="btn btn--outline-dark">Neem contact op</a>
        </div>
      )}
    </div>
  </section>

  <!-- ═══════════════════════════════════════ AUDIO -->
  <section class="section section--alt" aria-labelledby="audio-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="audio-heading">Luisterfragmenten</h2>
        <hr class="divider" />
        <p>Beluister fragmenten van ons koor.</p>
      </div>

      <div class="audio-list">
        <div class="audio-item">
          <div class="audio-meta">
            <span class="audio-tag">Bas-partij</span>
            <h3 class="audio-title">Du, du liegst mir im Herzen</h3>
            <p class="audio-desc">Basoefening, Nr. 304</p>
          </div>
          <audio controls class="audio-player" preload="none">
            <source src={`${base}/images/Du,%20liegst%20mir%20im%20Herzen%20-%20bas.m4a`} type="audio/mp4" />
            Uw browser ondersteunt geen audio-element.
          </audio>
        </div>

        <!-- Add more <div class="audio-item"> blocks here for additional recordings -->
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PHOTO GALLERY (lightbox) -->
  <section class="section" aria-labelledby="gallery-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="gallery-heading">Fotogalerij</h2>
        <hr class="divider" />
        <p>Klik op een foto voor een grotere weergave.</p>
      </div>

      <div class="photo-gallery" role="list">
        {galleryPhotos.map((photo, i) => (
          <button
            class="gallery-btn"
            data-src={`${base}/images/${photo.src}`}
            data-alt={photo.alt}
            data-index={i}
            aria-label={`${photo.alt}, foto ${i + 1} van ${galleryPhotos.length} vergroot bekijken`}
            role="listitem"
          >
            <img
              src={`${base}/images/${photo.src}`}
              alt={photo.alt}
              class="gallery-photo"
              loading="lazy"
              decoding="async"
            />
          </button>
        ))}
      </div>

      <!-- Lightbox -->
      <div id="lightbox" class="lightbox" hidden aria-modal="true" role="dialog" aria-label="Foto vergroot">
        <button class="lightbox-close" id="lightbox-close" aria-label="Sluiten">&#10005;</button>
        <button class="lightbox-prev" id="lightbox-prev" aria-label="Vorige foto">&#8592;</button>
        <button class="lightbox-next" id="lightbox-next" aria-label="Volgende foto">&#8594;</button>
        <div class="lightbox-inner">
          <img id="lightbox-img" src="" alt="" class="lightbox-photo" />
          <p id="lightbox-caption" class="lightbox-caption"></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ DOWNLOADS -->
  <section class="section section--alt" aria-labelledby="downloads-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="downloads-heading">Downloads</h2>
        <hr class="divider" />
        <p>Bladmuziek, flyers en andere documenten.</p>
      </div>

      <div class="downloads-list">
        <a
          href={`${base}/images/WERVINGSFLYERPROJECTKOOR2026.pdf`}
          class="download-item"
          download
          target="_blank"
          rel="noopener"
          aria-label="Download wervingsflyer Projectkoor 2026 als PDF"
        >
          <span class="download-icon" aria-hidden="true">&#128196;</span>
          <div class="download-info">
            <span class="download-name">Wervingsflyer Projectkoor 2026</span>
            <span class="download-type">PDF</span>
          </div>
          <span class="download-arrow" aria-hidden="true">&#8595;</span>
        </a>

        <a
          href={`${base}/images/Nr,304%20Du,%20du%20liegst%20mir%20im%20Herzen.pdf`}
          class="download-item"
          download
          target="_blank"
          rel="noopener"
          aria-label="Download bladmuziek Nr. 304 Du du liegst mir im Herzen als PDF"
        >
          <span class="download-icon" aria-hidden="true">&#127926;</span>
          <div class="download-info">
            <span class="download-name">Nr. 304 — Du, du liegst mir im Herzen</span>
            <span class="download-type">Bladmuziek · PDF</span>
          </div>
          <span class="download-arrow" aria-hidden="true">&#8595;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════ PRESS -->
  <section class="section" aria-labelledby="press-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="press-heading">In de pers</h2>
        <hr class="divider" />
      </div>

      <div class="press-list">
        <article class="press-item">
          <div class="press-source">BN De Stem / Gooi en Eemlander</div>
          <h3 class="press-title">Baarns MannenKoor viert 115-jarig bestaan met groots concert</h3>
          <p class="press-date">2022</p>
          <p class="press-excerpt">
            "Het Baarns MannenKoor liet vrijdagavond horen waarom het al meer dan
            een eeuw standhoudt. Met een programma dat de gehele koorsgeschiedenis
            omspande, brachten de zangers een ontroerend eerbetoon aan 115 jaar
            muzikale traditie."
          </p>
        </article>

        <article class="press-item">
          <div class="press-source">Baarnse Courant</div>
          <h3 class="press-title">Kerstconcert mannenkoor trekt volle zaal</h3>
          <p class="press-date">December 2023</p>
          <p class="press-excerpt">
            "De kerk zat tot de nok toe vol toen het Baarns MannenKoor zijn
            jaarlijkse kerstconcert gaf. Dirigent Mark Walter leidde het koor
            door een gevarieerd programma dat eindigde met een staande ovatie."
          </p>
        </article>

        <article class="press-item">
          <div class="press-source">RTV Eem</div>
          <h3 class="press-title">Mannenkoor zoekt nieuwe zangers: 'Notenlezen niet nodig'</h3>
          <p class="press-date">2023</p>
          <p class="press-excerpt">
            "Het Baarns MannenKoor opent zijn deuren voor nieuwe leden. Dirigent
            Walter benadrukt dat notenlezen geen vereiste is: 'We leren iedereen
            het vak. Wat je meebrengt is een goede stem en enthousiasme.'"
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Press contact -->
  <section class="section--dark section" aria-labelledby="press-contact-heading">
    <div class="container press-contact-row">
      <div>
        <h2 id="press-contact-heading">Perscontact</h2>
        <p>Journalist of mediamaker? Wij staan open voor interviews en samenwerking.</p>
      </div>
      <a href={`${base}/contact`} class="btn btn--primary">Neem contact op</a>
    </div>
  </section>
</Layout>

<script>
  // ── VIDEO CAROUSEL ──────────────────────────────────────────
  const track = document.getElementById('video-track');
  const dots = document.querySelectorAll<HTMLButtonElement>('.dot');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  if (track && dots.length > 0) {
    let current = 0;

    function goTo(index: number) {
      current = (index + dots.length) % dots.length;
      (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => d.classList.toggle('dot--active', i === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));
  }

  // ── LIGHTBOX ────────────────────────────────────────────────
  const lightbox = document.getElementById('lightbox') as HTMLElement | null;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lbCaption = document.getElementById('lightbox-caption');
  const lbClose = document.getElementById('lightbox-close');
  const lbPrev = document.getElementById('lightbox-prev');
  const lbNext = document.getElementById('lightbox-next');
  const galleryBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-btn'));

  let lbIndex = 0;

  function openLightbox(index: number) {
    lbIndex = index;
    const btn = galleryBtns[lbIndex];
    if (lbImg) {
      lbImg.src = btn.dataset.src || '';
      lbImg.alt = btn.dataset.alt || '';
    }
    if (lbCaption) lbCaption.textContent = btn.dataset.alt || '';
    if (lightbox) {
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      lbClose?.focus();
    }
  }

  function closeLightbox() {
    if (lightbox) {
      lightbox.hidden = true;
      document.body.style.overflow = '';
      galleryBtns[lbIndex]?.focus();
    }
  }

  function shiftLightbox(dir: number) {
    openLightbox((lbIndex + dir + galleryBtns.length) % galleryBtns.length);
  }

  galleryBtns.forEach((btn, i) => btn.addEventListener('click', () => openLightbox(i)));
  lbClose?.addEventListener('click', closeLightbox);
  lbPrev?.addEventListener('click', () => shiftLightbox(-1));
  lbNext?.addEventListener('click', () => shiftLightbox(1));

  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.hidden) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') shiftLightbox(-1);
    if (e.key === 'ArrowRight') shiftLightbox(1);
  });
</script>

<style>
  /* ── VIDEO CAROUSEL ── */
  .video-carousel {
    max-width: 800px;
    margin-inline: auto;
  }

  .video-track-wrap {
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .video-track {
    display: flex;
    transition: transform 0.35s ease;
  }

  .video-slide {
    flex: 0 0 100%;
  }

  .video-embed-wrap {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: #000;
  }

  .video-embed-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .video-caption {
    text-align: center;
    margin-top: var(--space-md);
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .video-year { opacity: 0.7; }

  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-lg);
    margin-top: var(--space-lg);
  }

  .carousel-btn {
    background: var(--color-primary);
    color: var(--color-white);
    border: none;
    border-radius: 50%;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition);
  }

  .carousel-btn:hover { background: var(--color-primary-light); }

  .carousel-dots { display: flex; gap: var(--space-sm); }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition: background var(--transition);
  }

  .dot--active { background: var(--color-accent); }

  .video-placeholder {
    text-align: center;
    padding: var(--space-3xl) var(--space-xl);
    background: var(--color-white);
    border: 2px dashed var(--color-border);
    border-radius: var(--radius-lg);
    max-width: 520px;
    margin-inline: auto;
  }

  .video-placeholder-icon {
    display: block;
    font-size: 3rem;
    color: var(--color-accent);
    opacity: 0.5;
    margin-bottom: var(--space-lg);
  }

  .video-placeholder h3 { margin-bottom: var(--space-sm); }
  .video-placeholder p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: var(--space-xl);
    max-width: 40ch;
    margin-inline: auto;
  }

  /* ── AUDIO ── */
  .audio-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .audio-item {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
    align-items: center;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  .audio-meta { flex: 1; min-width: 200px; }

  .audio-tag {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    display: block;
    margin-bottom: var(--space-xs);
  }

  .audio-title {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin-bottom: var(--space-xs);
  }

  .audio-desc {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .audio-player {
    width: 100%;
    max-width: 420px;
    accent-color: var(--color-accent);
  }

  /* ── GALLERY + LIGHTBOX ── */
  .photo-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-sm);
  }

  @media (min-width: 480px) { .photo-gallery { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 860px) { .photo-gallery { grid-template-columns: repeat(4, 1fr); } }

  .gallery-btn {
    border: none;
    padding: 0;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    overflow: hidden;
    display: block;
  }

  .gallery-photo {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .gallery-btn:hover .gallery-photo,
  .gallery-btn:focus-visible .gallery-photo {
    transform: scale(1.04);
    opacity: 0.88;
  }

  .gallery-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(5, 10, 20, 0.93);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
  }

  .lightbox[hidden] { display: none; }

  .lightbox-inner {
    max-width: 90vw;
    max-height: 90vh;
    text-align: center;
  }

  .lightbox-photo {
    max-width: 100%;
    max-height: 80vh;
    object-fit: contain;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
  }

  .lightbox-caption {
    color: rgba(255,255,255,0.75);
    font-size: 0.9rem;
    margin-top: var(--space-md);
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: fixed;
    background: rgba(255,255,255,0.12);
    border: none;
    color: #fff;
    font-size: 1.5rem;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
    z-index: 1001;
  }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover { background: rgba(255,255,255,0.25); }

  .lightbox-close { top: 1.25rem; right: 1.25rem; }
  .lightbox-prev  { left: 1rem;  top: 50%; transform: translateY(-50%); }
  .lightbox-next  { right: 1rem; top: 50%; transform: translateY(-50%); }

  /* ── DOWNLOADS ── */
  .downloads-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 640px;
  }

  .download-item {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg) var(--space-xl);
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
    transition: box-shadow var(--transition), border-color var(--transition);
  }

  .download-item:hover {
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .download-icon { font-size: 1.8rem; flex-shrink: 0; }

  .download-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .download-name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
  }

  .download-type {
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .download-arrow {
    font-size: 1.3rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* ── PRESS ── */
  .press-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .press-item {
    background: var(--color-white);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    border-left: 4px solid var(--color-accent);
    box-shadow: var(--shadow-sm);
  }

  .press-source {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    margin-bottom: var(--space-xs);
  }

  .press-title { font-size: 1.1rem; margin-bottom: var(--space-xs); }
  .press-date { font-size: 0.82rem; color: var(--color-text-light); margin-bottom: var(--space-md); }
  .press-excerpt { font-style: italic; color: var(--color-text-muted); font-size: 0.95rem; margin: 0; line-height: 1.7; }

  /* ── PRESS CONTACT ROW ── */
  .press-contact-row {
