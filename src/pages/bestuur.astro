---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

// SHA-256 of password "bmBoard!" — update hash to change password
// New hash: echo -n "newpassword" | sha256sum
const PASSWORD_HASH = "63a4f03298e1e0afc4d860c276fbf834b2fee38dd38ce091fe7af15e4fded60a";

// Every file below is additionally encrypted with the same password
// (PDFs: pikepdf AES-256 / R6 owner+user password; docx: msoffcrypto-tool ECMA-376 agile encryption)
// so the document itself asks for the password even if the direct URL leaks.
const DOCUMENTEN = [
  { title: "Begroting Najaarsconcert 2026 (intern)", bestand: "Begroting Najaarsconcert 2026 (intern).pdf" },
  { title: "Speeldoos brochure — 4 oktober", bestand: "Speeldoos brochure - 4 oktober.pdf" },
  { title: "Subsidieaanvraag VSBfonds 2025", bestand: "Subsidieaanvraag VSBfonds 2025.docx" },
  { title: "Subsidieaanvraag gemeente Baarn 2026", bestand: "Subsidieaanvraag gemeente Baarn 2026.docx" },
  { title: "Optreden Parkgebouw — 4 juli 2026", bestand: "Optreden Parkgebouw 4 juli 2026.docx" },
];
---

<Layout
  title="Bestuur"
  description="Besloten pagina voor bestuursleden van het Baarns MannenKoor."
  activePage="bestuur"
>
  <Hero
    title="Bestuur"
    subtitle="Baarns MannenKoor"
    description="Interne documenten voor bestuursleden."
    backgroundImage={`${base}/images/8782@2x.jpg`}
    compact={true}
  />

  <section class="section">
    <div class="container">

      <!-- Password gate -->
      <div id="password-gate" class="gate-wrap">
        <div class="gate-card">
          <h2>Inloggen</h2>
          <p>Alleen toegankelijk voor bestuursleden van het koor.</p>
          <form id="gate-form" autocomplete="off">
            <label for="pw-input" class="gate-label">Wachtwoord</label>
            <div class="gate-row">
              <input type="password" id="pw-input" class="gate-input" placeholder="Wachtwoord" required autofocus />
              <button type="submit" class="btn btn--primary">Inloggen</button>
            </div>
            <p id="gate-error" class="gate-error" aria-live="polite"></p>
          </form>
          <p class="gate-hint">Wachtwoord vergeten? Neem contact op met de secretaris.</p>
        </div>
      </div>

      <!-- Protected content -->
      <div id="bestuur-content" hidden>

        <div class="section-header">
          <h2>Documenten</h2>
          <hr class="divider" />
          <p>
            Elk document is naast deze pagina ook zelf met een wachtwoord
            beveiligd (zelfde wachtwoord als hierboven).
          </p>
        </div>

        <div class="doc-list">
          {DOCUMENTEN.map((doc) => (
            <div class="doc-item">
              <span class="doc-title">{doc.title}</span>
              <a
                href={`${base}/bestuur-documenten/${doc.bestand}`}
                class="btn btn--outline-dark btn--sm"
                download
              >Downloaden</a>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>
</Layout>

<script define:vars={{ PASSWORD_HASH }}>
  const SESSION_KEY = "bmk_bestuur_auth";

  async function sha256(msg) {
    const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(msg));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,"0")).join("");
  }

  function unlock() {
    document.getElementById("password-gate").hidden = true;
    document.getElementById("bestuur-content").hidden = false;
  }

  if (sessionStorage.getItem(SESSION_KEY) === "1") unlock();

  document.getElementById("gate-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const input = document.getElementById("pw-input");
    const hash = await sha256(input.value);
    if (hash === PASSWORD_HASH) {
      sessionStorage.setItem(SESSION_KEY, "1");
      unlock();
    } else {
      document.getElementById("gate-error").textContent = "Onjuist wachtwoord. Probeer opnieuw.";
      input.value = "";
      input.focus();
    }
  });
</script>

<style>
  .gate-wrap {
    display: flex;
    justify-content: center;
    padding-block: var(--space-2xl);
  }

  .gate-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-2xl) var(--space-3xl);
    max-width: 420px;
    width: 100%;
    box-shadow: var(--shadow-md);
    text-align: center;
  }

  .gate-card h2 { margin-bottom: var(--space-sm); }
  .gate-card > p { color: var(--color-text-muted); font-size: 0.95rem; margin-bottom: var(--space-xl); }

  .gate-label {
    display: block;
    text-align: left;
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-xs);
  }

  .gate-row { display: flex; gap: var(--space-sm); width: 100%; }

  .gate-input {
    flex: 1;
    min-width: 0;
    padding: 0.65rem var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
  }

  .gate-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(201,146,58,0.15);
  }

  .gate-error { color: #c0392b; font-size: 0.88rem; min-height: 1.2em; margin: var(--space-sm) 0 0; }
  .gate-hint { margin-top: var(--space-lg); font-size: 0.82rem; color: var(--color-text-light); }

  /* Documents */
  .doc-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .doc-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-accent);
    border-radius: var(--radius-lg);
    padding: var(--space-lg) var(--space-xl);
  }

  .doc-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    color: var(--color-primary);
  }

  .btn--sm { font-size: 0.85rem; padding: 0.45rem 1rem; }
</style>
