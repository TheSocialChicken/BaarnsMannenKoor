---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Geschiedenis"
  description="Meer dan 115 jaar Baarns MannenKoor — lees over de rijke geschiedenis van een van de oudste mannenkoren van Nederland."
  activePage="history"
>
  <Hero
    title="Onze geschiedenis"
    subtitle="1907 – heden"
    description="Meer dan een eeuw muziek, gemeenschap en continuïteit in Baarn."
    compact={true}
  />

  <!-- Opening narrative -->
  <section class="section" aria-labelledby="history-intro">
    <div class="container">
      <div class="prose-layout">
        <div class="prose">
          <h2 id="history-intro">Een koor dat de tand des tijds doorstond</h2>
          <hr class="divider" />
          <p>
            Het Baarns MannenKoor werd opgericht in <strong>1907</strong>, in een tijd
            dat zingen in een koor voor veel Nederlanders een van de weinige vormen van
            georganiseerde vrije tijdsbesteding was. Een handvol Baarnse mannen met een
            gedeelde liefde voor meerstemmige koorzang legde de basis voor wat vandaag
            een van de langst bestaande actieve mannenkoren van Nederland is.
          </p>
          <p>
            Meer dan 115 jaar later zingt het koor nog steeds. Generaties mannen zijn
            lid geweest, hebben meegezongen bij herdenkingen, kerkdiensten en concerten,
            en hebben hun stem gegeven aan een gemeenschap die altijd meer was dan alleen
            muziek. Het koor overleefde twee wereldoorlogen, decennia van maatschappelijke
            verandering en de teloorgang van menig koor om zich heen — en staat er sterker
            voor dan ooit.
          </p>
        </div>

        <aside class="history-aside">
          <div class="aside-box">
            <div class="aside-year">1907</div>
            <p>Oprichting van het Baarns MannenKoor in Baarn, Noord-Holland.</p>
          </div>
          <img
            src={`${base}/images/choir-banner.png`}
            alt="Het vaandel van het Baarns MannenKoor, opgericht 1907"
            class="history-banner-img"
          />
        </aside>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section section--alt" aria-labelledby="timeline-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="timeline-heading">Tijdlijn</h2>
        <hr class="divider" />
        <p>Enkele mijlpalen uit meer dan een eeuw koorsang.</p>
      </div>

      <ol class="timeline" aria-label="Tijdlijn van het koor">
        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">1907</div>
            <h3>Oprichting</h3>
            <p>
              Een groep Baarnse mannen richt het koor op. De vroegste repetities
              vinden plaats in een lokale zaal. Het koor kiest voor een breed
              repertoire van klassieke koormuziek en volksliederen.
            </p>
            <div class="timeline-photos">
              <img
                src={`${base}/images/history-founder-portrait.jpg`}
                alt="Portret van een van de oprichters van het Baarns MannenKoor, 1907"
                class="timeline-photo"
              />
              <img
                src={`${base}/images/history-1907-group.jpg`}
                alt="Vroege groepsfoto van het Baarns MannenKoor, circa 1907"
                class="timeline-photo"
              />
            </div>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">1914–1918</div>
            <h3>Eerste Wereldoorlog</h3>
            <p>
              Ook tijdens de oorlogsjaren blijft het koor bestaan. Zingen biedt
              troost en saamhorigheid in een onzekere tijd. Het koor speelt een
              rol bij lokale herdenkingen en bijeenkomsten.
            </p>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">1930s</div>
            <h3>Groei en uitbreiding</h3>
            <p>
              Het ledenaantal groeit. Het koor treedt op in de wijde omgeving van
              Baarn en bouwt een naam op als een koor van kwaliteit en betrouwbaarheid.
            </p>
            <div class="timeline-photos">
              <img
                src={`${base}/images/history-mid-group.jpg`}
                alt="Groepsfoto van het koor in de jaren dertig"
                class="timeline-photo"
              />
              <img
                src={`${base}/images/history-early-group.jpg`}
                alt="Vroege groepsfoto van het Baarns MannenKoor"
                class="timeline-photo"
              />
            </div>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">1940–1945</div>
            <h3>Tweede Wereldoorlog</h3>
            <p>
              De oorlog treft Baarn zwaar. Toch weet het koor de draad vast te
              houden. Na de bevrijding in 1945 zingt het koor mee bij de
              bevrijdingsfeesten — een onvergetelijk moment in de koorsgeschiedenis.
            </p>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">1957</div>
            <h3>50-jarig jubileum</h3>
            <p>
              Het koor viert zijn halve eeuw bestaan met een groot jubileumconcert.
              Oud-leden, dirigenten en vrienden komen bijeen om een bijzonder moment
              te herdenken en te vieren.
            </p>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">1980s–1990s</div>
            <h3>Nieuwe generaties</h3>
            <p>
              Het koor vernieuwt zich met nieuwe leden en een breder repertoire.
              Samenwerking met andere ensembles en optredens bij regionale evenementen
              versterken de positie van het koor in de koorgemeenschap.
            </p>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">2007</div>
            <h3>100-jarig jubileum</h3>
            <p>
              Een jubileumjaar met meerdere bijzondere concerten, een historisch
              overzicht en een feestelijk bijeenkomst voor leden, oud-leden en
              vrienden. Het koor blikt trots terug op een eeuw muzikale dienstverlening
              aan de gemeenschap van Baarn.
            </p>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">2017</div>
            <h3>Mark Walter als dirigent</h3>
            <p>
              Mark Walter treedt aan als nieuwe dirigent. Onder zijn leiding ontwikkelt
              het koor een verfijndere benadering van meerstemmigheid en gaat het
              ambitieuzer repertoire zingen. De saamhorigheid en het plezier in het
              zingen nemen toe.
            </p>
          </div>
        </li>

        <li class="timeline-item">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-dot"></span>
          </div>
          <div class="timeline-content">
            <div class="timeline-year">Heden</div>
            <h3>Meer dan 115 jaar en actief als nooit tevoren</h3>
            <p>
              Het Baarns MannenKoor zingt, groeit en bloeit. Met wekelijkse
              repetities, jaarlijkse concerten en een warme gemeenschap van
              leden kijkt het koor met vertrouwen naar de toekomst.
            </p>
            <img
              src={`${base}/images/8794@2x.jpg`}
              alt="Baarns MannenKoor op het podium, recent optreden"
              class="timeline-photo"
            />
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- Philosophy / Identity -->
  <section class="section" aria-labelledby="identity-heading">
    <div class="container">
      <div class="prose-layout">
        <div class="prose">
          <h2 id="identity-heading">Meer dan muziek</h2>
          <hr class="divider" />
          <p>
            Wat het Baarns MannenKoor bijzonder maakt, is niet alleen de muziek
            maar de gemeenschap eromheen. Generaties Baarnse mannen hebben in dit
            koor vriendschappen gesloten die een leven lang duurden. Collega's,
            buren, vaders en zonen — ze zongen allemaal naast elkaar.
          </p>
          <p>
            Dat gemeenschapsgevoel is tot op de dag van vandaag voelbaar. Een
            repetitie is niet alleen muzikaal werk; het is ook een avond met
            gelijkgestemden, een plek waar je even kunt ontsnappen aan de dagelijkse
            drukte en je helemaal kunt overgeven aan het gezamenlijk produceren van
            klank.
          </p>
          <p>
            Wij zijn trots op onze 115-jarige erfenis, maar kijken altijd vooruit.
            Ons doel is niet museumstuk te zijn, maar levende muziek te maken die
            mensen raakt.
          </p>
        </div>

        <blockquote class="pull-quote">
          <p>
            "Zingen in een koor is meer dan noten lezen. Het is luisteren, voelen,
            en je stem geven aan iets groters dan jezelf."
          </p>
          <cite>— Een lid van het Baarns MannenKoor</cite>
        </blockquote>
      </div>
    </div>
  </section>
</Layout>

<style>
  .prose-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  @media (min-width: 860px) {
    .prose-layout {
      grid-template-columns: 1fr 300px;
    }
  }

  .prose p {
    max-width: 70ch;
  }

  /* Aside box */
  .history-aside {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .aside-box {
    background-color: var(--color-primary);
    color: var(--color-white);
    padding: var(--space-xl);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-accent);
  }

  .aside-year {
    font-family: var(--font-heading);
    font-size: 3rem;
    color: var(--color-accent-light);
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .aside-box p {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.95rem;
    margin: 0;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 0;
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: 18px;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-accent) 0%,
      var(--color-border) 100%
    );
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
    position: relative;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-marker {
    display: flex;
    justify-content: center;
    padding-top: 4px;
    flex-shrink: 0;
  }

  .timeline-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background-color: var(--color-accent);
    border: 3px solid var(--color-bg-alt);
    box-shadow: 0 0 0 2px var(--color-accent);
    flex-shrink: 0;
  }

  .timeline-content {
    padding-bottom: var(--space-lg);
  }

  .timeline-year {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    margin-bottom: var(--space-xs);
  }

  .timeline-content h3 {
    font-size: 1.1rem;
    margin-bottom: var(--space-sm);
  }

  .timeline-content p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    max-width: 65ch;
    margin: 0;
  }

  .history-banner-img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    margin-top: var(--space-md);
  }

  .timeline-photos {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .timeline-photos .timeline-photo {
    margin-top: 0;
    max-width: 220px;
  }

  .timeline-photo {
    margin-top: var(--space-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    max-width: 320px;
    width: 100%;
    filter: grayscale(20%);
  }

  /* Pull quote */
  .pull-quote {
    background-color: var(--color-primary);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    border-left: 4px solid var(--color-accent);
    margin: 0;
  }

  .pull-quote p {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.92);
    line-height: 1.6;
    margin: 0 0 var(--space-md);
  }

  .pull-quote cite {
    font-size: 0.85rem;
    color: var(--color-accent-light);
    font-style: normal;
  }
</style>
