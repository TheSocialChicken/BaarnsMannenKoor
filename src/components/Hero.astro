---
export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  ctaPrimary?: { label: string; href: string };
  ctaSecondary?: { label: string; href: string };
  backgroundImage?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  description,
  ctaPrimary,
  ctaSecondary,
  backgroundImage,
  compact = false,
} = Astro.props;
---

<section class={`hero ${compact ? "hero--compact" : ""} ${backgroundImage ? "hero--photo" : ""}`} aria-label="Introductie">
  <div class="hero-bg" aria-hidden="true">
    {backgroundImage
      ? <div class="hero-photo" style={`background-image: url('${backgroundImage}')`}></div>
      : <div class="hero-pattern"></div>
    }
    <div class="hero-overlay"></div>
  </div>
  <div class="hero-content container">
    {subtitle && <p class="hero-eyebrow">{subtitle}</p>}
    <h1 class="hero-title">{title}</h1>
    {description && <p class="hero-description">{description}</p>}
    {(ctaPrimary || ctaSecondary) && (
      <div class="hero-actions">
        {ctaPrimary && (
          <a href={ctaPrimary.href} class="btn btn--primary">{ctaPrimary.label}</a>
        )}
        {ctaSecondary && (
          <a href={ctaSecondary.href} class="btn btn--outline">{ctaSecondary.label}</a>
        )}
      </div>
    )}
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero--compact {
    min-height: 280px;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  /* CSS-pattern fallback (no photo) */
  .hero-pattern {
    position: absolute;
    inset: 0;
    background-color: var(--color-primary);
    background-image:
      repeating-linear-gradient(
        135deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.018) 40px,
        rgba(255, 255, 255, 0.018) 80px
      ),
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(255, 255, 255, 0.012) 40px,
        rgba(255, 255, 255, 0.012) 80px
      );
  }

  /* Photo background */
  .hero-photo {
    position: absolute;
    inset: 0;
    background-color: var(--color-primary);
    background-position: center 30%;
    background-size: cover;
    background-repeat: no-repeat;
    transform: scale(1.03);
  }

  /* Overlay: heavier for photo, lighter for pattern */
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      160deg,
      rgba(10, 18, 36, 0.72) 0%,
      rgba(15, 26, 52, 0.55) 55%,
      rgba(10, 18, 36, 0.45) 100%
    );
  }

  .hero--photo .hero-overlay {
    background: linear-gradient(
      to right,
      rgba(8, 15, 30, 0.82) 0%,
      rgba(8, 15, 30, 0.65) 50%,
      rgba(8, 15, 30, 0.35) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-4xl);
    max-width: 700px;
  }

  .hero--compact .hero-content {
    padding-block: var(--space-2xl);
  }

  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent-light);
    margin-bottom: var(--space-md);
  }

  .hero-title {
    color: var(--color-white);
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: var(--space-lg);
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
  }

  .hero-description {
    color: rgba(255, 255, 255, 0.88);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    max-width: 52ch;
    line-height: 1.65;
    margin-bottom: var(--space-xl);
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  @media (min-width: 640px) {
    .hero {
      min-height: 640px;
    }
    .hero--compact {
      min-height: 320px;
    }
  }
</style>
